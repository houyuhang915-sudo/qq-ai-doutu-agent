ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 优先填写已开通的 Endpoint ID（ep- 开头）；若账号支持直接用 Model ID，也可改填可用模型名。
ARK_ENDPOINT_ID=
ARK_MODEL=doubao-seed-2-0-pro-260215
# 视觉模型可删掉这一行走自动判断，或显式设为 true。
ARK_SUPPORTS_IMAGE=true

MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5
# mimo-v2.5 / mimo-v2-omni 支持图片理解；如果切文本模型，可显式改成 false
MIMO_SUPPORTS_IMAGE=true

# 默认模型提供方：ark / mimo
DEFAULT_MODEL_PROVIDER=ark
PORT=8787
